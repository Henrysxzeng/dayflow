<view style="padding:32rpx 32rpx 160rpx;">

  <view bindtap="openTemplates" style="background:#EFF6FF; border-radius:16rpx; padding:20rpx 28rpx; margin-bottom:32rpx; display:flex; align-items:center; justify-content:space-between;">
    <text style="font-size:28rpx; color:#2563EB;">📋 从模板快速添加</text>
    <text style="color:#2563EB;">›</text>
  </view>

  <view style="margin-bottom:40rpx;">
    <view style="font-size:26rpx; color:#6B7280; margin-bottom:12rpx;">任务名称</view>
    <input class="card" style="height:80rpx; padding:0 28rpx; font-size:32rpx; color:#111827;" placeholder="例：完成季度报告" placeholder-style="color:#D1D5DB;" bindinput="handleTitleInput" value="{{form.title}}" />
  </view>

  <view style="margin-bottom:40rpx;">
    <view style="font-size:26rpx; color:#6B7280; margin-bottom:12rpx;">截止日期</view>
    <picker mode="date" bindchange="handleDeadlineChange" value="{{form.deadlineDate}}">
      <view class="card row-between" style="padding:24rpx 28rpx; margin-bottom:16rpx;">
        <text style="font-size:30rpx; color:{{form.deadlineDate ? '#111827' : '#D1D5DB'}};">{{form.deadlineDate || '选择日期（可不填）'}}</text>
        <text style="color:#6B7280;">›</text>
      </view>
    </picker>
    <picker wx:if="{{form.deadlineDate}}" mode="time" start="00:00" end="23:59" bindchange="handleDeadlineTimeChange" value="{{form.deadlineTime || '09:00'}}">
      <view class="card row-between" style="padding:20rpx 28rpx;">
        <view>
          <text style="font-size:22rpx; color:#9CA3AF; display:block; margin-bottom:4rpx;">截止时间（精确到几点）</text>
          <text style="font-size:28rpx; color:{{form.deadlineTime ? '#111827' : '#D1D5DB'}};">{{form.deadlineTime || '可不填'}}</text>
        </view>
        <text style="color:#2563EB; font-size:24rpx;">选择 ›</text>
      </view>
    </picker>
  </view>

  <view wx:if="{{form.deadlineDate}}" style="margin-bottom:40rpx;">
    <view style="font-size:26rpx; color:#6B7280; margin-bottom:12rpx;">截止前提醒</view>
    <scroll-view scroll-x style="white-space:nowrap; margin-bottom:12rpx;">
      <view wx:for="{{[{label:'不提醒',v:0},{label:'15分前',v:15},{label:'30分前',v:30},{label:'1小时前',v:60},{label:'2小时前',v:120},{label:'1天前',v:1440},{label:'自定义',v:-1}]}}" wx:key="v"
        class="chip {{(form.reminderMinutesBefore === item.v && !form.showCustomReminder) || (item.v === -1 && form.showCustomReminder) ? 'active' : ''}}"
        style="display:inline-flex;" bindtap="handleReminderSelect" data-v="{{item.v}}"
      >{{item.label}}</view>
    </scroll-view>
    <view wx:if="{{form.showCustomReminder}}" style="background:#F9FAFB; border-radius:14rpx; padding:16rpx 24rpx; display:flex; align-items:center;">
      <input type="number" placeholder="输入分钟数" bindinput="handleCustomReminderInput" style="flex:1; height:64rpx; font-size:28rpx; color:#111827;" />
      <text style="color:#6B7280; font-size:26rpx; margin-left:12rpx;">分钟前</text>
    </view>
    <text wx:if="{{form.reminderMinutesBefore > 0}}" style="font-size:22rpx; color:#6B7280; display:block; margin-top:8rpx;">⚡ 通过订阅消息提醒</text>
  </view>

  <view style="margin-bottom:40rpx;">
    <view class="row-between" style="margin-bottom:12rpx;">
      <text style="font-size:26rpx; color:#6B7280;">预计用时</text>
      <text wx:if="{{form.estimatedMinutes > 0 && form.estimatedMinutes <= 10}}" style="font-size:22rpx; color:#D97706;">⚡ 短任务，进随手清空</text>
    </view>
    <scroll-view scroll-x style="white-space:nowrap; margin-bottom:16rpx;">
      <view wx:for="{{durationOptions}}" wx:key="value"
        class="chip {{!showDurationPicker && form.estimatedMinutes === item.value ? 'active' : (showDurationPicker && item.value === -1 ? 'active' : '')}}"
        style="display:inline-flex;" bindtap="handleDurationSelect" data-value="{{item.value}}"
      >{{item.value === -1 ? durationLabel : item.label}}</view>
    </scroll-view>
    <view wx:if="{{showDurationPicker}}" class="card" style="padding:16rpx 24rpx;">
      <picker mode="multiSelector" range="{{durationPickerRange}}" value="{{durationPickerValue}}" bindchange="handleDurationPickerChange" style="width:100%;">
        <view class="row" style="justify-content:center; align-items:center; padding:16rpx 0;">
          <text style="font-size:36rpx; font-weight:700; color:#2563EB;">{{durationLabel}}</text>
          <text style="font-size:24rpx; color:#9CA3AF; margin-left:16rpx;">上下滑动选择 ›</text>
        </view>
      </picker>
      <view bindtap="cancelDurationPicker" style="text-align:center; padding:12rpx 0;">
        <text style="font-size:26rpx; color:#6B7280;">收起</text>
      </view>
    </view>
  </view>

  <view style="margin-bottom:40rpx;">
    <view style="font-size:26rpx; color:#6B7280; margin-bottom:12rpx;">重要程度</view>
    <view class="row">
      <view wx:for="{{importanceOptions}}" wx:key="value" class="chip {{form.importance === item.value ? 'active' : ''}}" bindtap="handleImportanceSelect" data-value="{{item.value}}">{{item.label}}</view>
    </view>
  </view>

  <view style="margin-bottom:40rpx;">
    <view style="font-size:26rpx; color:#6B7280; margin-bottom:12rpx;">时间安排</view>
    <view class="row" style="background:#F9FAFB; border-radius:16rpx; padding:8rpx; margin-bottom:16rpx;">
      <view bindtap="switchSchedulingMode" data-mode="ai" style="flex:1; text-align:center; padding:16rpx 0; border-radius:12rpx; background:{{form.schedulingMode === 'ai' ? '#2563EB' : 'transparent'}};">
        <text style="font-size:26rpx; color:{{form.schedulingMode === 'ai' ? '#FFF' : '#6B7280'}}; font-weight:{{form.schedulingMode === 'ai' ? '600' : '400'}};">🤖 AI 帮我安排</text>
      </view>
      <view bindtap="switchSchedulingMode" data-mode="manual" style="flex:1; text-align:center; padding:16rpx 0; border-radius:12rpx; background:{{form.schedulingMode === 'manual' ? '#2563EB' : 'transparent'}};">
        <text style="font-size:26rpx; color:{{form.schedulingMode === 'manual' ? '#FFF' : '#6B7280'}}; font-weight:{{form.schedulingMode === 'manual' ? '600' : '400'}};">🔒 我来定时间</text>
      </view>
    </view>
    <view wx:if="{{form.schedulingMode === 'ai'}}">
      <text style="font-size:22rpx; color:#9CA3AF; display:block; margin-bottom:12rpx;">可选：希望在什么时间做（AI尽量参考）</text>
      <picker mode="time" start="06:00" end="23:00" bindchange="handlePreferredTimeChange" value="{{form.preferredTime || '09:00'}}">
        <view style="background:#F9FAFB; border-radius:14rpx; padding:18rpx 24rpx; display:flex; align-items:center; justify-content:space-between;">
          <text style="font-size:28rpx; color:{{form.preferredTime ? '#111827' : '#D1D5DB'}};">{{form.preferredTime || '不指定（让AI自动选）'}}</text>
          <text style="color:#2563EB; font-size:24rpx;">选择 ›</text>
        </view>
      </picker>
    </view>
    <view wx:if="{{form.schedulingMode === 'manual'}}">
      <text style="font-size:22rpx; color:#DC2626; display:block; margin-bottom:12rpx;">⚠️ 固定后AI重新生成不会移动此任务</text>
      <picker mode="time" start="06:00" end="23:00" bindchange="handleLockedTimeChange" value="{{form.lockedStartTime || '09:00'}}">
        <view style="background:#FEF3C7; border-radius:14rpx; padding:18rpx 24rpx; border:2rpx solid #FDE68A;">
          <view class="row-between">
            <text style="font-size:28rpx; color:{{form.lockedStartTime ? '#92400E' : '#D97706'}}; font-weight:600;">🔒 开始：{{form.lockedStartTime || '点击设置'}}</text>
            <text style="color:#D97706; font-size:24rpx;">选择 ›</text>
          </view>
          <view wx:if="{{form.lockedStartTime}}" style="margin-top:8rpx;">
            <text style="font-size:24rpx; color:#92400E;">结束：{{form.lockedEndTime}}（共{{form.estimatedMinutes}}分钟）</text>
          </view>
        </view>
      </picker>
    </view>
  </view>

  <view style="margin-bottom:48rpx;">
    <view style="font-size:26rpx; color:#6B7280; margin-bottom:12rpx;">备注（选填）</view>
    <textarea class="card" style="padding:24rpx 28rpx; font-size:28rpx; color:#374151; width:100%; min-height:120rpx; box-sizing:border-box;" placeholder="补充说明..." placeholder-style="color:#D1D5DB;" bindinput="handleDescInput" value="{{form.description}}" />
  </view>

  <view class="btn-primary" bindtap="handleSubmit" style="{{!form.title ? 'opacity:0.4;' : ''}}">
    {{isEditMode ? '保存修改' : '添加任务'}}
  </view>

</view>

<view wx:if="{{showTemplates}}" style="position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.5); z-index:999;" bindtap="closeTemplates">
  <view style="position:absolute; bottom:0; left:0; right:0; background:#FFF; border-radius:32rpx 32rpx 0 0; padding:32rpx 0 80rpx;" catchtap="noop">
    <view class="row-between" style="padding:0 32rpx 20rpx;">
      <text style="font-size:32rpx; font-weight:700; color:#111827;">选择模板</text>
      <text bindtap="closeTemplates" style="font-size:28rpx; color:#6B7280;">关闭</text>
    </view>
    <scroll-view scroll-x style="white-space:nowrap; padding:0 32rpx; margin-bottom:16rpx;">
      <view wx:for="{{templateCategories}}" wx:key="name" bindtap="switchTemplateCategory" data-index="{{index}}"
        style="display:inline-block; padding:12rpx 28rpx; border-radius:40rpx; margin-right:12rpx; background:{{activeTemplateCategory === index ? '#2563EB' : '#F3F4F6'}}; font-size:26rpx; color:{{activeTemplateCategory === index ? '#FFF' : '#374151'}};">{{item.name}}</view>
      <view bindtap="switchTemplateCategory" data-index="{{templateCategories.length}}"
        style="display:inline-block; padding:12rpx 28rpx; border-radius:40rpx; background:{{activeTemplateCategory === templateCategories.length ? '#2563EB' : '#F3F4F6'}}; font-size:26rpx; color:{{activeTemplateCategory === templateCategories.length ? '#FFF' : '#374151'}};">⭐ 我的</view>
    </scroll-view>
    <scroll-view scroll-y style="max-height:500rpx; padding:0 32rpx;" wx:if="{{activeTemplateCategory < templateCategories.length}}">
      <view wx:for="{{templateCategories[activeTemplateCategory].templates}}" wx:key="title" bindtap="applyTemplate" data-title="{{item.title}}" data-minutes="{{item.minutes}}"
        style="padding:24rpx 0; border-bottom:1rpx solid #F3F4F6; display:flex; align-items:center; justify-content:space-between;">
        <text style="font-size:30rpx; color:#111827;">{{item.title}}</text>
        <text style="font-size:24rpx; color:#6B7280;">{{item.minutes < 60 ? item.minutes + '分' : (item.minutes/60) + 'h'}}</text>
      </view>
    </scroll-view>
    <scroll-view scroll-y style="max-height:500rpx; padding:0 32rpx;" wx:if="{{activeTemplateCategory === templateCategories.length}}">
      <view wx:if="{{customTemplates.length === 0 && !showAddCustomTemplate}}" style="text-align:center; padding:48rpx 0; color:#9CA3AF; font-size:26rpx;">还没有自定义模板</view>
      <view wx:for="{{customTemplates}}" wx:key="id" style="padding:20rpx 0; border-bottom:1rpx solid #F3F4F6; display:flex; align-items:center;">
        <view bindtap="applyTemplate" data-title="{{item.title}}" data-minutes="{{item.minutes}}" style="flex:1; display:flex; align-items:center; justify-content:space-between;">
          <text style="font-size:28rpx; color:#111827;">{{item.title}}</text>
          <text style="font-size:24rpx; color:#6B7280; margin-right:16rpx;">{{item.minutes}}分</text>
        </view>
        <view bindtap="deleteCustomTemplate" data-id="{{item.id}}" style="padding:8rpx 14rpx; background:#FEE2E2; border-radius:10rpx;">
          <text style="font-size:24rpx; color:#EF4444;">删除</text>
        </view>
      </view>
      <view wx:if="{{!showAddCustomTemplate}}" bindtap="openAddCustomTemplate" style="margin-top:20rpx; padding:20rpx; border:2rpx dashed #D1D5DB; border-radius:16rpx; text-align:center;">
        <text style="font-size:26rpx; color:#2563EB;">+ 添加自定义模板</text>
      </view>
      <view wx:else style="margin-top:20rpx; background:#F9FAFB; border-radius:16rpx; padding:24rpx;">
        <input placeholder="模板名称" bindinput="handleNewTemplateTitleInput" value="{{newTemplateTitle}}" style="height:72rpx; background:#FFF; border-radius:12rpx; padding:0 16rpx; font-size:28rpx; color:#111827; margin-bottom:16rpx; width:100%; box-sizing:border-box;" />
        <view class="row" style="align-items:center; margin-bottom:16rpx; gap:12rpx;">
          <input type="number" placeholder="分钟数" bindinput="handleNewTemplateMinutesInput" value="{{newTemplateMinutes}}" style="flex:1; height:72rpx; background:#FFF; border-radius:12rpx; padding:0 16rpx; font-size:28rpx; color:#111827;" />
          <text style="font-size:26rpx; color:#6B7280;">分钟</text>
        </view>
        <view class="btn-primary" style="height:80rpx; font-size:26rpx;" bindtap="saveCustomTemplate">保存模板</view>
      </view>
    </scroll-view>
  </view>
</view>
