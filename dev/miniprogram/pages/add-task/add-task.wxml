<view style="padding:32rpx 32rpx 160rpx;">

  <!-- 快速模板按钮 -->
  <view bindtap="openTemplates" style="background:#EFF6FF; border-radius:16rpx; padding:20rpx 28rpx; margin-bottom:32rpx; display:flex; align-items:center; justify-content:space-between;">
    <text style="font-size:28rpx; color:#2563EB;">📋 从模板快速添加</text>
    <text style="color:#2563EB;">›</text>
  </view>

  <!-- 任务名称 -->
  <view style="margin-bottom:40rpx;">
    <view style="font-size:26rpx; color:#6B7280; margin-bottom:12rpx;">任务名称</view>
    <input
      class="card"
      style="padding:28rpx; font-size:32rpx; color:#111827;"
      placeholder="例：完成季度报告"
      placeholder-style="color:#D1D5DB;"
      bindinput="handleTitleInput"
      value="{{form.title}}"
    />
  </view>

  <!-- 截止日期 -->
  <view style="margin-bottom:40rpx;">
    <view style="font-size:26rpx; color:#6B7280; margin-bottom:12rpx;">截止日期</view>
    <picker mode="date" bindchange="handleDeadlineChange" value="{{form.deadlineDate}}">
      <view class="card row-between" style="padding:28rpx; margin-bottom:16rpx;">
        <text style="font-size:30rpx; color:{{form.deadlineDate ? '#111827' : '#D1D5DB'}};">
          {{form.deadlineDate || '选择日期（可不填）'}}
        </text>
        <text style="color:#6B7280;">›</text>
      </view>
    </picker>
    <!-- 时间选择：仅在选了日期后显示 -->
    <picker wx:if="{{form.deadlineDate}}" mode="time" start="00:00" end="23:59" bindchange="handleDeadlineTimeChange" value="{{form.deadlineTime || '09:00'}}">
      <view class="card row-between" style="padding:24rpx 28rpx;">
        <view>
          <text style="font-size:24rpx; color:#9CA3AF; display:block; margin-bottom:4rpx;">截止时间（几点几分）</text>
          <text style="font-size:30rpx; color:{{form.deadlineTime ? '#111827' : '#D1D5DB'}};">
            {{form.deadlineTime || '点击选择，可不填'}}
          </text>
        </view>
        <text style="color:#2563EB; font-size:24rpx;">选择 ›</text>
      </view>
    </picker>
  </view>

  <!-- 预计用时 -->
  <view style="margin-bottom:40rpx;">
    <view class="row-between" style="margin-bottom:12rpx;">
      <text style="font-size:26rpx; color:#6B7280;">预计用时</text>
      <text wx:if="{{form.estimatedMinutes > 0 && form.estimatedMinutes <= 10}}" style="font-size:22rpx; color:#D97706;">⚡ 短任务，进随手清空</text>
    </view>
    <scroll-view scroll-x style="white-space:nowrap; margin-bottom:16rpx;">
      <view
        wx:for="{{durationOptions}}"
        wx:key="value"
        class="chip {{(!showCustomDuration && form.estimatedMinutes === item.value) || (showCustomDuration && item.value === -1) ? 'active' : ''}}"
        style="display:inline-flex;"
        bindtap="handleDurationSelect"
        data-value="{{item.value}}"
      >{{item.label}}</view>
    </scroll-view>
    <!-- 自定义分钟数输入框 -->
    <view wx:if="{{showCustomDuration}}" class="row" style="align-items:center; background:#F9FAFB; border-radius:16rpx; padding:20rpx 24rpx;">
      <input
        type="number"
        placeholder="输入分钟数"
        placeholder-style="color:#D1D5DB;"
        bindinput="handleCustomDurationInput"
        value="{{customDurationText}}"
        style="flex:1; font-size:32rpx; color:#111827;"
        focus="{{true}}"
      />
      <text style="color:#6B7280; font-size:28rpx; margin-left:12rpx;">分钟</text>
    </view>
  </view>

  <!-- 重要程度 -->
  <view style="margin-bottom:40rpx;">
    <view style="font-size:26rpx; color:#6B7280; margin-bottom:12rpx;">重要程度</view>
    <view class="row">
      <view
        wx:for="{{importanceOptions}}"
        wx:key="value"
        class="chip {{form.importance === item.value ? 'active' : ''}}"
        bindtap="handleImportanceSelect"
        data-value="{{item.value}}"
      >{{item.label}}</view>
    </view>
  </view>

  <!-- 备注 -->
  <view style="margin-bottom:48rpx;">
    <view style="font-size:26rpx; color:#6B7280; margin-bottom:12rpx;">备注（选填）</view>
    <textarea
      class="card"
      style="padding:28rpx; font-size:28rpx; color:#374151; width:100%; min-height:120rpx; box-sizing:border-box;"
      placeholder="补充说明..."
      placeholder-style="color:#D1D5DB;"
      bindinput="handleDescInput"
      value="{{form.description}}"
    />
  </view>

  <!-- 提交 -->
  <view class="btn-primary" bindtap="handleSubmit" style="{{!form.title ? 'opacity:0.4;' : ''}}">
    添加任务
  </view>

</view>

<!-- 模板选择浮层 -->
<view wx:if="{{showTemplates}}" style="position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.5); z-index:999;" bindtap="closeTemplates">
  <view style="position:absolute; bottom:0; left:0; right:0; background:#FFF; border-radius:32rpx 32rpx 0 0; padding:32rpx 0 80rpx;" catchtap="">
    <view class="row-between" style="padding:0 32rpx 24rpx;">
      <text style="font-size:32rpx; font-weight:700; color:#111827;">选择模板</text>
      <text bindtap="closeTemplates" style="font-size:28rpx; color:#6B7280;">关闭</text>
    </view>
    <!-- 分类 tabs -->
    <scroll-view scroll-x style="white-space:nowrap; padding:0 32rpx; margin-bottom:24rpx;">
      <view
        wx:for="{{templateCategories}}"
        wx:key="name"
        bindtap="switchTemplateCategory"
        data-index="{{index}}"
        style="display:inline-block; padding:12rpx 28rpx; border-radius:40rpx; margin-right:16rpx; background:{{activeTemplateCategory === index ? '#2563EB' : '#F3F4F6'}}; font-size:26rpx; color:{{activeTemplateCategory === index ? '#FFF' : '#374151'}};"
      >{{item.name}}</view>
    </scroll-view>
    <!-- 模板列表 -->
    <view style="padding:0 32rpx; max-height:500rpx; overflow:hidden;">
      <view
        wx:for="{{templateCategories[activeTemplateCategory].templates}}"
        wx:key="title"
        bindtap="applyTemplate"
        data-title="{{item.title}}"
        data-minutes="{{item.minutes}}"
        style="padding:24rpx 0; border-bottom:1rpx solid #F3F4F6; display:flex; align-items:center; justify-content:space-between;"
      >
        <text style="font-size:30rpx; color:#111827;">{{item.title}}</text>
        <text style="font-size:24rpx; color:#6B7280;">{{item.minutes < 60 ? item.minutes + '分钟' : (item.minutes/60) + '小时'}}</text>
      </view>
    </view>
  </view>
</view>
