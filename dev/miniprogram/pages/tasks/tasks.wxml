<view class="page-container">

  <!-- Tab 切换 -->
  <view class="row" style="margin-bottom:32rpx; border-bottom:1rpx solid #F3F4F6;">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      bindtap="handleTabChange"
      data-key="{{item.key}}"
      style="flex:1; text-align:center; padding:20rpx 0; font-size:28rpx; font-weight:{{activeTab === item.key ? '600' : '400'}}; color:{{activeTab === item.key ? '#2563EB' : '#6B7280'}}; border-bottom:{{activeTab === item.key ? '4rpx solid #2563EB' : '4rpx solid transparent'}};"
    >{{item.label}}</view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{filteredTasks.length === 0 && q1Tasks.length === 0 && q2Tasks.length === 0 && fragmentTasks.length === 0}}" style="text-align:center; padding:120rpx 0; color:#9CA3AF; font-size:28rpx;">
    <text style="display:block; font-size:80rpx; margin-bottom:24rpx;">📋</text>
    <text>还没有任务</text>
  </view>

  <!-- Q1 紧急且重要 -->
  <view wx:if="{{q1Tasks.length > 0 && activeTab !== 'completed'}}">
    <view style="font-size:24rpx; font-weight:600; color:#DC2626; margin-bottom:16rpx;">🔴 紧急且重要</view>
    <view wx:for="{{q1Tasks}}" wx:key="_id" class="card row-between" style="padding:24rpx 28rpx; margin-bottom:16rpx; align-items:flex-start;">
      <view style="flex:1;" bindtap="handleTaskTap" data-id="{{item._id}}">
        <view style="font-size:30rpx; font-weight:500; color:#111827; margin-bottom:8rpx;">{{item.title}}</view>
        <view class="row">
          <text style="font-size:24rpx; color:#DC2626; margin-right:20rpx;">{{item.deadlineDisplay}}</text>
          <text style="font-size:24rpx; color:#6B7280;">{{item.durationDisplay}}</text>
        </view>
      </view>
      <view style="display:flex; align-items:center; gap:8rpx;">
        <view bindtap="startPomodoro" data-id="{{item._id}}" data-title="{{item.title}}" style="background:#FEF3C7; border-radius:12rpx; padding:8rpx 14rpx;">
          <text style="font-size:24rpx; color:#92400E;">🍅</text>
        </view>
        <view bindtap="handleDeleteTask" data-id="{{item._id}}" style="padding:8rpx 12rpx;">
          <text style="font-size:32rpx; color:#D1D5DB;">···</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Q2 重要不紧急 -->
  <view wx:if="{{q2Tasks.length > 0 && activeTab !== 'completed'}}">
    <view style="font-size:24rpx; font-weight:600; color:#2563EB; margin-bottom:16rpx; margin-top:8rpx;">🔵 重要，不紧急</view>
    <view wx:for="{{q2Tasks}}" wx:key="_id" class="card row-between" style="padding:24rpx 28rpx; margin-bottom:16rpx; align-items:flex-start;">
      <view style="flex:1;" bindtap="handleTaskTap" data-id="{{item._id}}">
        <view style="font-size:30rpx; font-weight:500; color:#111827; margin-bottom:8rpx;">{{item.title}}</view>
        <view class="row">
          <text style="font-size:24rpx; color:#6B7280; margin-right:20rpx;">{{item.deadlineDisplay}}</text>
          <text style="font-size:24rpx; color:#6B7280;">{{item.durationDisplay}}</text>
        </view>
      </view>
      <view style="display:flex; align-items:center; gap:8rpx;">
        <view bindtap="startPomodoro" data-id="{{item._id}}" data-title="{{item.title}}" style="background:#FEF3C7; border-radius:12rpx; padding:8rpx 14rpx;">
          <text style="font-size:24rpx; color:#92400E;">🍅</text>
        </view>
        <view bindtap="handleDeleteTask" data-id="{{item._id}}" style="padding:8rpx 12rpx;">
          <text style="font-size:32rpx; color:#D1D5DB;">···</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 随手清空 -->
  <view wx:if="{{fragmentTasks.length > 0 && activeTab !== 'completed'}}">
    <view style="font-size:24rpx; font-weight:600; color:#D97706; margin-bottom:16rpx; margin-top:8rpx;">⚡ 随手清空</view>
    <view wx:for="{{fragmentTasks}}" wx:key="_id" class="card row-between" style="padding:20rpx 28rpx; margin-bottom:12rpx; align-items:center;">
      <view style="flex:1;" bindtap="handleTaskTap" data-id="{{item._id}}">
        <text style="font-size:28rpx; color:#374151;">{{item.title}}</text>
        <text style="font-size:22rpx; color:#9CA3AF; margin-left:16rpx;">{{item.durationDisplay}}</text>
      </view>
      <view bindtap="handleDeleteTask" data-id="{{item._id}}" style="padding:8rpx 12rpx; margin-left:16rpx;">
        <text style="font-size:32rpx; color:#D1D5DB;">···</text>
      </view>
    </view>
  </view>

  <!-- 已完成列表 -->
  <view wx:if="{{activeTab === 'completed'}}">
    <view wx:for="{{filteredTasks}}" wx:key="_id" class="card row-between" style="padding:24rpx 28rpx; margin-bottom:16rpx; opacity:0.7; align-items:center;">
      <view style="flex:1;">
        <view style="font-size:28rpx; color:#6B7280; text-decoration:line-through;">{{item.title}}</view>
        <text style="font-size:22rpx; color:#9CA3AF;">{{item.completedAtDisplay}}</text>
      </view>
      <view style="display:flex; align-items:center; gap:8rpx;">
        <view bindtap="handleRestoreTask" data-id="{{item._id}}" style="background:#F0FDF4; border-radius:12rpx; padding:8rpx 16rpx;">
          <text style="font-size:22rpx; color:#16A34A; font-weight:600;">恢复</text>
        </view>
        <view bindtap="handleDeleteTask" data-id="{{item._id}}" style="padding:8rpx 12rpx;">
          <text style="font-size:32rpx; color:#E5E7EB;">···</text>
        </view>
      </view>
    </view>
  </view>

</view>

<!-- 新建按钮 -->
<view style="position:fixed; bottom:120rpx; right:32rpx;">
  <view bindtap="goAddTask" style="width:112rpx; height:112rpx; border-radius:56rpx; background:#2563EB; display:flex; align-items:center; justify-content:center; box-shadow:0 8rpx 24rpx rgba(37,99,235,0.4);">
    <text style="color:#FFF; font-size:52rpx; line-height:1; margin-top:-4rpx;">+</text>
  </view>
</view>
