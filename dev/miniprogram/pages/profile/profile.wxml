<view class="page-container">

  <!-- 用户信息 -->
  <view class="card row" style="margin-top:24rpx; margin-bottom:32rpx;">
    <view style="width:96rpx; height:96rpx; border-radius:48rpx; background:#EFF6FF; display:flex; align-items:center; justify-content:center; margin-right:28rpx;">
      <text style="font-size:48rpx;">🌊</text>
    </view>
    <view>
      <text style="font-size:32rpx; font-weight:600; color:#111827;">Flow 用户</text>
      <text style="display:block; font-size:24rpx; color:#6B7280; margin-top:8rpx;">本周完成 {{totalCompleted}} 件</text>
    </view>
    <view style="margin-left:auto; text-align:center;">
      <text style="display:block; font-size:48rpx; font-weight:700; color:#F97316;">{{streak}}</text>
      <text style="font-size:20rpx; color:#6B7280;">连续天</text>
    </view>
  </view>

  <!-- 社区月度挑战 -->
  <view wx:if="{{challenge}}" style="margin-bottom:32rpx;">
    <text style="font-size:24rpx; color:#6B7280; font-weight:600; letter-spacing:2rpx; display:block; margin-bottom:16rpx;">本月社区挑战</text>
    <view class="card" style="{{challengeCompleted ? 'background:#F0FDF4; border:2rpx solid #BBF7D0;' : ''}}">
      <view class="row-between" style="margin-bottom:16rpx;">
        <view>
          <text style="font-size:28rpx; font-weight:700; color:#111827; display:block;">🏆 {{challenge.title}}</text>
          <text style="font-size:24rpx; color:#6B7280; margin-top:4rpx; display:block;">{{challenge.desc}}</text>
        </view>
        <text wx:if="{{challengeCompleted}}" style="font-size:24rpx; color:#16A34A; font-weight:600;">已完成✓</text>
        <text wx:elif="{{challengeDaysLeft > 0}}" style="font-size:22rpx; color:#9CA3AF;">剩{{challengeDaysLeft}}天</text>
      </view>

      <!-- 进度条 -->
      <view wx:if="{{challengeHasJoined}}" style="margin-bottom:16rpx;">
        <view class="row-between" style="margin-bottom:8rpx;">
          <text style="font-size:22rpx; color:#6B7280;">进度 {{challengeProgress}}/{{challenge.goal_value}}</text>
          <text style="font-size:22rpx; color:#2563EB;">{{challengeProgressPct}}%</text>
        </view>
        <view style="background:#F3F4F6; border-radius:8rpx; height:12rpx; overflow:hidden;">
          <view style="background:{{challengeCompleted ? '#16A34A' : '#2563EB'}}; height:100%; width:{{challengeProgressPct}}%; border-radius:8rpx;"></view>
        </view>
      </view>

      <!-- 参与人数 -->
      <view class="row-between" style="margin-top:16rpx;">
        <text style="font-size:22rpx; color:#6B7280;">👥 {{challengeParticipants}} 人参与</text>
        <view wx:if="{{!challengeHasJoined}}" class="btn-primary" style="height:64rpx; padding:0 32rpx; font-size:26rpx;" bindtap="handleJoinChallenge">加入挑战</view>
        <text wx:else style="font-size:22rpx; color:#16A34A; font-weight:600;">✓ 已参与</text>
      </view>
    </view>
  </view>

  <!-- 分享本月成绩：必须用 button open-type="share" -->
  <button open-type="share" style="background:#1E3A8A; border-radius:20rpx; padding:32rpx; margin-bottom:32rpx; display:flex; align-items:center; justify-content:space-between; width:100%; box-sizing:border-box; text-align:left;">
    <view>
      <text style="font-size:28rpx; font-weight:600; color:#FFF; display:block;">分享本月成绩</text>
      <text style="font-size:22rpx; color:rgba(255,255,255,0.6); margin-top:6rpx; display:block;">完成 {{totalCompleted}} 件 · 连续 {{streak}} 天</text>
    </view>
    <text style="font-size:40rpx;">📤</text>
  </button>

  <!-- 每周 AI 总结 -->
  <view wx:if="{{weeklySummary || loadingSummary}}" style="margin-bottom:32rpx; background:#EFF6FF; border-radius:20rpx; padding:32rpx;">
    <text style="font-size:22rpx; color:#6B7280; display:block; margin-bottom:12rpx;">Flow 的本周总结</text>
    <view wx:if="{{loadingSummary}}" style="color:#6B7280; font-size:26rpx;">生成中...</view>
    <text wx:else style="font-size:28rpx; color:#1D4ED8; line-height:44rpx;">{{weeklySummary}}</text>
  </view>

  <!-- 成就徽章 -->
  <view wx:if="{{achievements.length > 0}}" style="margin-bottom:32rpx;">
    <text style="font-size:24rpx; color:#6B7280; font-weight:600; letter-spacing:2rpx; display:block; margin-bottom:16rpx;">成就</text>
    <view class="card">
      <view style="display:flex; flex-wrap:wrap; gap:16rpx;">
        <view wx:for="{{achievementBadges}}" wx:key="id" style="background:#F9FAFB; border-radius:12rpx; padding:16rpx 20rpx; display:flex; align-items:center;">
          <text style="font-size:32rpx; margin-right:8rpx;">{{item.emoji}}</text>
          <text style="font-size:22rpx; color:#374151;">{{item.name}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 七日完成率趋势 -->
  <view style="margin-bottom:32rpx;">
    <text style="font-size:24rpx; color:#6B7280; font-weight:600; letter-spacing:2rpx; display:block; margin-bottom:20rpx;">近 7 日完成率</text>
    <view class="card" style="padding:32rpx 24rpx;">
      <view class="row" style="align-items:flex-end; justify-content:space-between; height:140rpx;">
        <view
          wx:for="{{chartBars}}"
          wx:key="date"
          style="display:flex; flex-direction:column; align-items:center; flex:1;"
        >
          <view style="width:100%; display:flex; flex-direction:column; justify-content:flex-end; height:100rpx; padding:0 4rpx;">
            <view style="background:{{item.isRestDay ? '#D1FAE5' : (item.rate >= 80 ? '#2563EB' : (item.rate >= 50 ? '#93C5FD' : '#E5E7EB'))}}; border-radius:6rpx; height:{{item.rate}}rpx; min-height:{{item.rate > 0 ? 8 : 0}}rpx; width:100%;"></view>
          </view>
          <text style="font-size:18rpx; color:#9CA3AF; margin-top:8rpx;">{{item.date}}</text>
          <text style="font-size:18rpx; color:{{item.rate >= 80 ? '#2563EB' : '#9CA3AF'}};">{{item.isRestDay ? '休' : (item.rate > 0 ? item.rate + '%' : '-')}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 本周数据 -->
  <view style="margin-bottom:32rpx;">
    <text style="font-size:24rpx; color:#6B7280; font-weight:600; letter-spacing:2rpx; display:block; margin-bottom:16rpx;">本周数据</text>
    <view class="card">
      <view class="row" style="justify-content:space-around; text-align:center;">
        <view>
          <text style="display:block; font-size:48rpx; font-weight:700; color:#2563EB;">{{weekStats.completed}}</text>
          <text style="font-size:22rpx; color:#6B7280;">已完成</text>
        </view>
        <view style="width:1rpx; background:#F3F4F6;"></view>
        <view>
          <text style="display:block; font-size:48rpx; font-weight:700; color:#16A34A;">{{weekStats.rate}}%</text>
          <text style="font-size:22rpx; color:#6B7280;">完成率</text>
        </view>
        <view style="width:1rpx; background:#F3F4F6;"></view>
        <view>
          <text style="display:block; font-size:48rpx; font-weight:700; color:#F97316;">{{streak}}</text>
          <text style="font-size:22rpx; color:#6B7280;">连续天</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 时间校准分析 -->
  <view style="margin-bottom:32rpx;">
    <text style="font-size:24rpx; color:#6B7280; font-weight:600; letter-spacing:2rpx; display:block; margin-bottom:16rpx;">时间校准分析</text>
    <view class="card">
      <view wx:if="{{calibrationUnlocked}}">
        <view class="row" style="margin-bottom:16rpx;">
          <text style="font-size:40rpx; margin-right:16rpx;">🔬</text>
          <view>
            <text style="font-size:28rpx; font-weight:600; color:#111827; display:block;">已解锁</text>
            <text style="font-size:22rpx; color:#6B7280;">基于 {{calibrationDataPoints}} 个真实用时数据</text>
          </view>
        </view>
        <text style="font-size:26rpx; color:#374151; line-height:40rpx;">Flow 正在根据你的真实用时习惯优化未来的时间预估，让计划更贴合你的节奏。</text>
      </view>
      <view wx:else>
        <view class="row" style="margin-bottom:16rpx;">
          <text style="font-size:40rpx; margin-right:16rpx;">🔒</text>
          <view>
            <text style="font-size:28rpx; font-weight:600; color:#111827; display:block;">时间校准分析</text>
            <text style="font-size:22rpx; color:#6B7280;">{{calibrationDataPoints}}/10 个数据点</text>
          </view>
        </view>
        <!-- 进度条 -->
        <view style="background:#F3F4F6; border-radius:8rpx; height:12rpx; margin-bottom:16rpx; overflow:hidden;">
          <view style="background:#2563EB; height:100%; width:{{calibrationProgress}}%; border-radius:8rpx; transition:width 0.3s;"></view>
        </view>
        <text style="font-size:24rpx; color:#6B7280; line-height:38rpx;">再完成 {{10 - calibrationDataPoints}} 次任务并反馈实际用时，即可解锁。解锁后 Flow 将分析你的时间高估/低估规律，让每次计划更准确。</text>
      </view>
    </view>
  </view>

  <!-- 关于与隐私 -->
  <view style="margin-bottom:32rpx;">
    <navigator url="/pages/privacy/privacy" style="display:flex; align-items:center; justify-content:space-between; padding:28rpx 0; border-bottom:1rpx solid #F3F4F6;">
      <text style="font-size:30rpx; color:#374151;">隐私政策</text>
      <text style="color:#9CA3AF;">›</text>
    </navigator>
  </view>

  <!-- AI 风格 -->
  <view style="margin-bottom:32rpx;">
    <text style="font-size:24rpx; color:#6B7280; font-weight:600; letter-spacing:2rpx; display:block; margin-bottom:16rpx;">AI 风格</text>
    <view class="row">
      <view
        wx:for="{{aiToneOptions}}"
        wx:key="value"
        class="chip {{settings.aiTone === item.value ? 'active' : ''}}"
        bindtap="handleToneSelect"
        data-value="{{item.value}}"
      >{{item.label}}</view>
    </view>
  </view>

</view>
