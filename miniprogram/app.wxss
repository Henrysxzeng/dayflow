page {
  background-color: #FAFAFA;
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
  color: #111827;
  font-size: 30rpx;
  line-height: 44rpx;
  box-sizing: border-box;
}

.page-container {
  padding: 0 32rpx 160rpx;
}

.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

.section-subtitle {
  font-size: 24rpx;
  color: #6B7280;
}

.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #2563EB;
  color: #FFFFFF;
  border-radius: 20rpx;
  height: 96rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.btn-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F3F4F6;
  color: #374151;
  border-radius: 20rpx;
  height: 88rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.btn-ghost {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6B7280;
  height: 72rpx;
  font-size: 26rpx;
}

.chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 32rpx;
  border-radius: 40rpx;
  background: #F3F4F6;
  color: #374151;
  font-size: 28rpx;
  font-weight: 500;
  margin-right: 16rpx;
  white-space: nowrap;
}

.chip.active {
  background: #EFF6FF;
  color: #2563EB;
  border: 2rpx solid #BFDBFE;
}

.text-blue { color: #2563EB; }
.text-green { color: #16A34A; }
.text-red { color: #DC2626; }
.text-orange { color: #D97706; }
.text-gray { color: #6B7280; }
.text-light { color: #D1D5DB; }

.divider {
  height: 1rpx;
  background: #F3F4F6;
  margin: 16rpx 0;
}

.row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.row-between {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.flex-1 { flex: 1; }

.mt-8 { margin-top: 16rpx; }
.mt-16 { margin-top: 32rpx; }
.mt-24 { margin-top: 48rpx; }
.mb-8 { margin-bottom: 16rpx; }
.mb-16 { margin-bottom: 32rpx; }
